# ═══════════════════════════════════════════════════════════════
# MLA Planner — Variables d'environnement
# Copier ce fichier en .env et ajuster les valeurs si nécessaire.
# Les valeurs par défaut ci-dessous fonctionnent telles quelles
# avec docker compose up --build.
# NE JAMAIS COMMITER .env
# ═══════════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────────────
# Docker Compose : utiliser le service "db" comme host
DATABASE_URL=postgresql+psycopg2://mla:mla@db:5432/mla_db

# ── Backend ──────────────────────────────────────────────────────
ENV=development
PORT=8000

# Clé secrète JWT — changer impérativement en production
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000

# ── Superadmin Bootstrap ─────────────────────────────────────────
# Créé automatiquement au démarrage si inexistant
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=demo123!

# ── Email SMTP ───────────────────────────────────────────────────
# Laisser SMTP_USER et SMTP_PASS vides pour désactiver les emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@planning-mla.com
EMAIL_FROM_NAME=MLA Planner

# ── Frontend ─────────────────────────────────────────────────────
# URL de l'API vue depuis le navigateur (pas le réseau Docker interne)
# Baked dans le bundle au moment du build — rebuild requis si changée
NUXT_PUBLIC_API_BASE=http://localhost:8000

# ══════════════════════════════════════════════════════════════
# PRODUCTION UNIQUEMENT — remplir dans /opt/mla/.env sur le VPS
# ══════════════════════════════════════════════════════════════

# VPS_IP=85.184.92.137

# POSTGRES_USER=mla_user
# POSTGRES_PASSWORD=CHANGE_ME_strong_password_min_20_chars
# POSTGRES_DB=mla_db

# DATABASE_URL=postgresql+psycopg2://mla_user:CHANGE_ME@db:5432/mla_db
# JWT_SECRET_KEY=CHANGE_ME_minimum_32_characters_random_secret
# ENV=production

# SUPERADMIN_USERNAME=superadmin
# SUPERADMIN_PASSWORD=CHANGE_ME_superadmin_password

# ALLOWED_ORIGINS=https://85.184.92.137
# NUXT_PUBLIC_API_BASE=https://85.184.92.137/api
